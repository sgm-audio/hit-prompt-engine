# Copy to .env and fill in your keys

# ── Database ──────────────────────────────────────────────────────────────────
HIT_ENGINE_DB=hit_engine.db
# For PostgreSQL production:
# DATABASE_URL=postgresql://user:password@localhost:5432/hit_engine

# ── RapidAPI (Billboard genre charts + Spotify proxy) ─────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Spotify (native API — optional, used if RapidAPI unavailable) ──────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── MusicBrainz (no key needed — just set your contact for User-Agent) ─────────
MUSICBRAINZ_CONTACT=your_email@example.com

# ── Error tracking (optional) ─────────────────────────────────────────────────
# Create project in Sentry org sgm-studios, then paste DSN here.
SENTRY_DSN=
ENVIRONMENT=development
